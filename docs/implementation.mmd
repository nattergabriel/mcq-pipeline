graph TD

    %% Nodes

    Config[config.yaml]
    Env[.env]
    Prompts["prompts/*.txt"]
    PDFs["slides/*.pdf"]
    Main[main.py CLI]:::fill
    LLM_Client[src.llm_client]:::fill
    External_API[OpenAI API]

    %% Subgraphs for each module

    subgraph Extraction
        Extractor[src.pdf_extractor]:::fill
        Extracted_JSON[extracted_pdfs/*.json]
    end

    subgraph Generation
        Generator[src.mcqs_generator]:::fill
        Generated_JSON[generated_mcqs.json]
    end

    subgraph Evaluation
        Evaluator[src.mcqs_evaluator]:::fill
        Evaluated_JSON[evaluated_mcqs.json]
    end

    subgraph Export
        Exporter[src.mcqs_exporter]:::fill
        Filter{Quality Check}
        Final_XML[exported_mcqs.xml]
        Discard[Discard Question]
    end
    
    %% Edges

    Config --> Main
    Main -- "extract" --> Extractor
    Main -- "generate" --> Generator
    Main -- "evaluate" --> Evaluator
    Main -- "export" --> Exporter

    PDFs --> Extractor
    Extractor --> Extracted_JSON
    
    Extracted_JSON --> Generator
    Prompts --> Generator
    Generator --> Generated_JSON
    
    Generated_JSON --> Evaluator
    Prompts --> Evaluator
    Evaluator --> Evaluated_JSON
    
    Evaluated_JSON --> Exporter
    Exporter --> Filter
    Filter -- Yes --> Final_XML
    Filter -- No --> Discard

    Env --> LLM_Client
    Generator --> LLM_Client
    Evaluator --> LLM_Client
    LLM_Client <--> External_API


